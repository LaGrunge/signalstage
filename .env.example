# Copy to .env and fill in real secrets before deploying.

# --- app stack ---
POSTGRES_DB=signalstage
POSTGRES_USER=signalstage
POSTGRES_PASSWORD=change-me-app-db-password
JWT_SECRET=change-me-to-a-long-random-string

# Must match AUTHN_TOKEN in judge0/judge0.conf
JUDGE0_AUTH_TOKEN=change-me-judge0-token

# Port nginx (frontend) is published on, on the host
HTTP_PORT=80
